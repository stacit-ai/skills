default:
    @just --list

setup:
    cd training && uv sync

check:
    cd training && uv run ruff format --check .
    cd training && uv run ruff check .
    cd training && uv run pytest -m "not slow"

format:
    cd training && uv run ruff format .

lint:
    cd training && uv run ruff check .

test *args:
    cd training && uv run pytest {{ args }}

test-fast *args:
    cd training && uv run pytest -m "not slow" {{ args }}

check-integration:
    cd training && uv run pytest ../tests/integration -m "not slow"

train:
    @echo "Create the training workflow module, then replace this recipe."

eval:
    @echo "Create the evaluation workflow module, then replace this recipe."

service-test:
    @echo "Select a service framework, then replace this command with service tests."
