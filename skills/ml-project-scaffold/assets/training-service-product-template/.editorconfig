# EditorConfig helps maintain consistent coding styles
# for multiple developers working on the same project.
# https://editorconfig.org/
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 120

[*.lock]
charset = unset
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
indent_style = unset
indent_size = unset

[*.py]
indent_style = space
indent_size = 4

[*.{json,yml,yaml,toml}]
indent_style = space
indent_size = 2

[pyproject.toml]
indent_size = 4

[justfile]
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[LICENSE]
insert_final_newline = false
