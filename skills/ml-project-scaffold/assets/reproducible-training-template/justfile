default:
    @just --list

setup:
    uv sync
    uvx pre-commit install

check:
    uvx pre-commit run --all-files
    uv run pytest -m "not slow"

format:
    uv run ruff format .
    uv run ruff check --fix .

test *ARGS:
    uv run pytest {{ARGS}}

test-fast *ARGS:
    uv run pytest -m "not slow" {{ARGS}}

train:
    @echo "Create the training workflow module, then replace this recipe."

eval:
    @echo "Create the evaluation workflow module, then replace this recipe."

clean-outputs:
    rm -rf outputs/*
