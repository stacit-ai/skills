default:
    @just --list

setup:
    uv sync

check:
    uv run ruff format --check .
    uv run ruff check .
    uv run pytest -m "not slow"

format:
    uv run ruff format .

lint:
    uv run ruff check .

test *args:
    uv run pytest {{ args }}

test-fast *args:
    uv run pytest -m "not slow" {{ args }}

train:
    @echo "Create the training workflow module, then replace this recipe."

eval:
    @echo "Create the evaluation workflow module, then replace this recipe."

clean-outputs:
    rm -rf outputs/*
